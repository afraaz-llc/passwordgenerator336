# Security headers for Cloudflare Pages, applied to every route.
# The standout is `connect-src 'none'`: the browser will BLOCK any network
# request (fetch/XHR/WebSocket/beacon), so a generated password physically
# cannot leave the page. Our "never sent anywhere" promise, enforced.
/*
  Content-Security-Policy: default-src 'none'; style-src 'unsafe-inline'; script-src 'unsafe-inline'; img-src data:; connect-src 'none'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=()
